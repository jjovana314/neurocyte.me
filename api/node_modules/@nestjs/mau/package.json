{
  "name": "@nestjs/mau",
  "version": "0.2.4",
  "description": "Nest - modern, fast, powerful node.js web framework (@mau)",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "bin": {
    "mau": "bin/mau.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "gulp clean:bundle",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint '{lib,commands,actions}/**/*.ts' --fix",
    "start": "node bin/nest.js",
    "prepack": "npm run build",
    "prepublish:next": "npm run build",
    "publish:next": "npm publish --access public --tag next",
    "prepublish:npm": "npm run build",
    "publish:npm": "npm publish --access public",
    "test": "jest --config test/jest-config.json",
    "test:dev": "npm run clean && jest --config test/jest-config.json --watchAll",
    "prerelease": "npm run build",
    "release": "release-it",
    "prepare": "husky install"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "4.1.2",
    "cli-progress": "3.12.0",
    "commander": "4.1.1",
    "inquirer": "8.2.6",
    "node-emoji": "2.1.3",
    "ora": "5.4.1",
    "undici": "6.20.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.657.0",
    "@commitlint/cli": "18.6.0",
    "@commitlint/config-angular": "18.6.0",
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "9.0.3",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.16",
    "@types/node-emoji": "1.8.2",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "delete-empty": "3.0.0",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "gulp": "4.0.2",
    "gulp-clean": "0.4.0",
    "husky": "9.0.10",
    "jest": "29.7.0",
    "lint-staged": "15.2.2",
    "prettier": "3.2.5",
    "release-it": "17.0.3",
    "ts-jest": "29.1.2",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.3.3"
  },
  "lint-staged": {
    "**/*.{ts,json}": []
  }
}
